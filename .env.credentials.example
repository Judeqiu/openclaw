# Credential Management for OpenClaw Docker
# Copy this file to .env.credentials and fill in your actual values
# This file is gitignored by default

# =============================================================================
# TIER 1: Environment Variables (for simple tokens)
# These are passed to the container via docker-compose
# =============================================================================

# Web Search
BRAVE_API_KEY=your_brave_api_key_here

# Memory Trainer Bot
MEMORY_BOT_TOKEN=your_telegram_bot_token

# X/Twitter (if using environment instead of embedded script)
TWITTER_AUTH_TOKEN=your_auth_token
TWITTER_CT0=your_ct0_value

# Polymarket
POLYMARKET_API_KEY=your_api_key

# Email (Gmail App Password)
GMAIL_APP_PASSWORD=your_app_password

# =============================================================================
# TIER 2: File-based Credentials
# These should be placed in ~/.config/ on the host
# They will be mounted into the container
# =============================================================================

# Notion: ~/.config/notion/token.txt
# Moltbook: ~/.openclaw/workspace/.config/moltbook/credentials.json
# Calendar: ~/.openclaw/workspace/skills/calendar-intelligence/token.json
# AWS: ~/.aws/credentials (if needed)
# GCloud: ~/.config/gcloud/application_default_credentials.json (if needed)

# =============================================================================
# TIER 3: OpenClaw Native Auth
# These are stored in ~/.openclaw/ and already persisted
# =============================================================================

# Kimi/Moonshot API keys: ~/.openclaw/openclaw.json
# Telegram: ~/.openclaw/credentials/telegram-pairing.json
# Device auth: ~/.openclaw/identity/
